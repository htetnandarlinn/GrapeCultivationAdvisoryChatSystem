<IfModule mod_rewrite.c>
    RewriteEngine On

    # If the request isn't for an existing file or directory, forward to this index
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Send everything to the project's index.php front controller
    RewriteRule ^ index.php [QSA,L]
</IfModule>
